PORT=3000
DATABASE_URL=postgresql://devuser:dbpass@localhost:5432/devdb
# Use a completely separate database for automated tests.
# The test runner will refuse to touch DATABASE_URL if this isolated database is unavailable.
TEST_DATABASE_URL=postgresql://devuser:dbpass@localhost:5432/devdb_test
JWT_SECRET=replace-this-with-a-secure-secret
APP_ENV=development
# Leave false for normal local work. Set true only if you intentionally want the app itself to run against a disposable *_test database.
ALLOW_TEST_DATABASE_IN_DEV=false

# Score ingestion scheduler
# Enable automatic score polling on server startup.
SCORE_INGEST_ENABLED=false
# Source for score updates: mock, payload, or espn.
SCORE_INGEST_SOURCE=mock
# Slower polling cadence used before games are live.
SCORE_INGEST_INTERVAL_MINUTES=30
# Faster polling cadence used when games are near kickoff or in progress.
SCORE_INGEST_ACTIVE_INTERVAL_SECONDS=60
# Daily wake-up hour for the scheduler in Central Time.
SCORE_INGEST_DAILY_START_HOUR_CT=6
# Timeout for each outbound score-provider request.
SCORE_INGEST_REQUEST_TIMEOUT_MS=8000
# Optional team-name hint for matching ESPN scoreboard results.
SCORE_INGEST_PRIMARY_TEAM=
# While waiting for the next scheduled game, alternate the kiosk between the
# last completed game and the next upcoming game on this cadence.
DISPLAY_POSTGAME_ROTATION_SECONDS=15

SIMULATION_ENABLED=true
EMAIL_NOTIFICATIONS_ENABLED=true
EMAIL_FROM=noreply@footballpool.local
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
