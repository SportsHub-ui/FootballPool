{
  "name": "footballpool-backend",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "node ./scripts/run-migrations.js && tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node ./scripts/run-migrations.js && node dist/server.js",
    "start:server": "node dist/server.js",
    "test": "node ./scripts/run-vitest.js",
    "test:ui": "node ./scripts/run-vitest.js --ui",
    "test:run": "node ./scripts/run-vitest.js run",
    "lint": "eslint .",
    "db:migrate": "node ./scripts/run-migrations.js",
    "db:migrate:test": "node ./scripts/run-migrations.js --target=test",
    "db:clean": "node ./scripts/clean-db-data.js --target=dev",
    "db:clean:test": "node ./scripts/clean-db-data.js --target=test",
    "db:sync-sport-teams": "node ./scripts/sync-sport-teams.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^6.10.1",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.7.4",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^7.2.0",
    "@vitest/ui": "^4.1.2",
    "eslint": "^9.12.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^4.1.2"
  }
}
